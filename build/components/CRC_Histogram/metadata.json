      { "name": "dataValues",      "nickname": "val",  "description": "Data values to histogram (uses demo data if absent)",             "typeHintID": "float",     "scriptParamAccess": "list" },
      { "name": "numBins",         "nickname": "bins", "description": "Number of histogram bins (default 10)",                           "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "numXLabels",      "nickname": "nxL",  "description": "Number of X-axis labels (default: all bin edges)",               "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "numYLabels",      "nickname": "nyL",  "description": "Number of Y-axis labels (default 5)",                            "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "decimals",        "nickname": "dec",  "description": "Decimal places for labels (default 1)",                          "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "axisExtension",   "nickname": "axE",  "description": "Axis extension beyond canvas (default 0)",                       "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "labelDist",       "nickname": "lblD", "description": "Label distance from axis (default 10)",                          "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "drawGridY",       "nickname": "gY",   "description": "Draw horizontal grid lines at Y labels (default False)",         "typeHintID": "bool",      "scriptParamAccess": "item", "optional": true },
      { "name": "barOutlineWidth", "nickname": "barW", "description": "Bar outline width in pixels (default 1)",                        "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
