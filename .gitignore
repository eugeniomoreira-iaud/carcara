# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
# NOTE: no `build/` here — `build/` is now a SOURCE dir (GH component bundles +
# installer), renamed from `grasshopper/`. Packaging artifacts are covered by
# dist/, sdist/, wheels/, *.egg-info below.
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/

# Carcara-specific
*.ghuser
*.gh
# DO commit the built components shipped inside the deployable folder.
!release/userobjects/
!release/userobjects/*.ghuser
# DO commit the end-user installer definition (bootstrap only — no DB credentials).
!build/installer/carcara_setup_rev00.gh
tests/_manual/

# vendor: DLL is proprietary (copy from Rhino 8 or NuGet); componentizer is tracked
vendor/ghio/

# Credential scripts (never commit these)
_obsolete/test_*.py

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor swap / backup / scratch
*.swp
*.swo
*~
*.bak
*.orig
*.tmp

# IDEs (keep the shared VS Code settings, ignore per-user IDE files)
.idea/
.vscode/*
!.vscode/settings.json

# Local Claude Code settings (machine-specific permissions; never commit)
.claude/settings.local.json
