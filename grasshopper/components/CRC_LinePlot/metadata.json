  "ghpython": {
    "isAdvancedMode": true,
    "marshalGuids": true,
    "iconDisplay": 0,
    "inputParameters": [
      { "name": "canvasRect",    "description": "Canvas boundary Rectangle3d (default 100x100 at origin)",                                               "typeHintID": "rectangle", "scriptParamAccess": "item", "optional": true },
      { "name": "xValues",       "description": "X coordinates (flat list = 1 series; DataTree = multi). Uses demo data if absent.",                      "typeHintID": "float",     "scriptParamAccess": "list" },
      { "name": "yValues",       "description": "Y coordinates (same shape as xValues). Uses demo data if absent.",                                       "typeHintID": "float",     "scriptParamAccess": "list" },
      { "name": "numXLabels",    "description": "Number of X-axis labels (default 5)",                                                                    "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "numYLabels",    "description": "Number of Y-axis labels (default 5)",                                                                    "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "decimals",      "description": "Decimal places for labels (default 1)",                                                                  "typeHintID": "int",       "scriptParamAccess": "item", "optional": true },
      { "name": "axisExtension", "description": "Axis extension beyond canvas (default 0)",                                                               "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "labelDist",     "description": "Label distance from axis (default 10)",                                                                  "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "marginLeft",    "description": "Left margin as % of X range (default 0)",                                                               "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "marginBottom",  "description": "Bottom margin as % of Y range (default 0)",                                                             "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "drawGridX",     "description": "Draw vertical grid lines at X labels (default False)",                                                   "typeHintID": "bool",      "scriptParamAccess": "item", "optional": true },
      { "name": "drawGridY",     "description": "Draw horizontal grid lines at Y labels (default False)",                                                 "typeHintID": "bool",      "scriptParamAccess": "item", "optional": true },
      { "name": "lineWidth",     "description": "Series line width in pixels (default 2)",                                                                "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "axisLineWidth", "description": "Axis line width in pixels (default 2)",                                                                  "typeHintID": "float",     "scriptParamAccess": "item", "optional": true },
      { "name": "gridLineWidth", "description": "Grid line width in pixels (default 1)",                                                                  "typeHintID": "float",     "scriptParamAccess": "item", "optional": true }
    ],
    "outputParameters": [
      {
        "name": "svgCode",
        "description": "Raw SVG body content (no <svg> wrapper). Chain into CRC_SaveSVG for file export."
