{
  "name": "ScatterPlot",
  "nickname": "Scatter",
  "category": "Carcara",
  "subcategory": "04.Dataviz",
  "description": "Creates a scatter plot as Rhino geometry (dots, axes, grid, legend) and exports an SVG file. Full parametric control over dot radii, color gradient, margins, grid, and legend.",
  "exposure": 8,
  "instanceGuid": "b2c3d4e5-f6a7-8901-bcde-f23456789abc",
  "ghpython": {
    "isAdvancedMode": false,
    "marshalGuids": true,
    "iconDisplay": 0,
    "inputParameters": [
      { "name": "cv",         "description": "Canvas boundary rectangle (Rectangle3d)",                       "typeHintID": "ghdoc",  "scriptParamAccess": "item" },
      { "name": "x",          "description": "X coordinates of data points",                                   "typeHintID": "float",  "scriptParamAccess": "list" },
      { "name": "y",          "description": "Y coordinates of data points",                                   "typeHintID": "float",  "scriptParamAccess": "list" },
      { "name": "r",          "description": "Dot radius — single value or list for variable sizes (default 2.0)", "typeHintID": "float", "scriptParamAccess": "list" },
      { "name": "nx",         "description": "Number of X-axis labels (default 5)",                            "typeHintID": "int",    "scriptParamAccess": "item" },
      { "name": "ny",         "description": "Number of Y-axis labels (default 5)",                            "typeHintID": "int",    "scriptParamAccess": "item" },
      { "name": "d",          "description": "Decimal places for labels (default 1)",                          "typeHintID": "int",    "scriptParamAccess": "item" },
      { "name": "ext",        "description": "Axis extension beyond canvas (default 0)",                        "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "dist",       "description": "Label distance from axis (default 10.0)",                         "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "mx",         "description": "Left margin as % of X range (default 0)",                        "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "my",         "description": "Bottom margin as % of Y range (default 0)",                      "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "gx",         "description": "Draw vertical grid lines (default False)",                        "typeHintID": "bool",   "scriptParamAccess": "item" },
      { "name": "gy",         "description": "Draw horizontal grid lines (default False)",                      "typeHintID": "bool",   "scriptParamAccess": "item" },
      { "name": "show_leg",   "description": "Generate color legend (default False)",                           "typeHintID": "bool",   "scriptParamAccess": "item" },
      { "name": "col_vals",   "description": "Values for color mapping; if None uses Y values",                 "typeHintID": "float",  "scriptParamAccess": "list" },
      { "name": "colors",     "description": "Color gradient list (System.Drawing.Color, min 2, required if show_leg=True)", "typeHintID": "ghdoc", "scriptParamAccess": "list" },
      { "name": "n_leg",      "description": "Number of legend steps (default 5)",                             "typeHintID": "int",    "scriptParamAccess": "item" },
      { "name": "leg_w",      "description": "Legend bar width (default 5% of canvas)",                        "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "leg_dist",   "description": "Distance from chart to legend (default 20)",                     "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "leg_l_dist", "description": "Distance from legend bar to labels (default 5)",                 "typeHintID": "float",  "scriptParamAccess": "item" },
      { "name": "leg_orient", "description": "Legend orientation: 'vertical' or 'horizontal' (default 'vertical')", "typeHintID": "str", "scriptParamAccess": "item" },
      { "name": "OutPath",    "description": "Output SVG file path",                                           "typeHintID": "str",    "scriptParamAccess": "item" },
      { "name": "CToggle",    "description": "Set True to execute and save SVG",                               "typeHintID": "bool",   "scriptParamAccess": "item" }
    ],
    "outputParameters": [
      { "name": "dots",       "description": "Scatter plot circles (Circle)" },
      { "name": "colors_out", "description": "Dot colors (System.Drawing.Color per dot)" },
      { "name": "axes",       "description": "X and Y axis lines" },
      { "name": "x_pts",      "description": "X-axis label anchor points" },
      { "name": "x_txt",      "description": "X-axis label text" },
      { "name": "y_pts",      "description": "Y-axis label anchor points" },
      { "name": "y_txt",      "description": "Y-axis label text" },
      { "name": "grid_x",     "description": "Vertical grid lines" },
      { "name": "grid_y",     "description": "Horizontal grid lines" },
      { "name": "leg_cells",  "description": "Legend rectangles" },
      { "name": "leg_clrs",   "description": "Legend colors" },
      { "name": "leg_pts",    "description": "Legend label anchor points" },
      { "name": "leg_txt",    "description": "Legend label text" },
      { "name": "svg_code",   "description": "Complete SVG document string" },
      { "name": "svg_path",   "description": "Absolute path of saved SVG file (empty if not saved)" },
      { "name": "report",     "description": "Status message" }
    ]
  }
}
